        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https://ncjpbkfwhmsispiczzgl.supabase.co https://ncjpbkfwhmsispiczzgl.functions.supabase.co wss://ncjpbkfwhmsispiczzgl.supabase.co; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
        }
      ]
    }
  ],
  "rewrites": [
